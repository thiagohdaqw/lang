func soma(c, d):
    c + d
fim

func multiplicacao(aa, bb):
    aa * bb
fim

func div(a, b):
    func inner_div():
        a / b
    fim

    inner_div()
fim

resultado = soma(32, 10)
print("Soma 32 + 10 = ")
print(resultado)

resultado = multiplicacao(32, 10)
print("Multiplicacao 32 * 10 = ")
print(resultado)

resultado = div(32, 10)
print("Divisao 32 / 10 = ")
print(resultado)
